{
    "name": "ScunGun - PC setup",
    "build": {
        "dockerfile": "Dockerfile"
    },
    
    "workspaceFolder": "/home/ros/scun_gun_ws",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ros/scun_gun_ws/src,type=bind",
    
    "privileged": true,
    
    "runArgs": [
        "--network=host",
        "--ipc=host",
        "--gpus=all",
        "--volume=/dev:/dev",
        "--cap-add=SYS_NICE",
        "--ulimit=rtprio=99",
        "--ulimit=rttime=-1",
        "--ulimit=memlock=8428281856"
    ],
    
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.Xauthority,target=/home/ros/.Xauthority,type=bind"
    ],
    
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}",
        "QT_X11_NO_MITSHM": "1",
        "ROS_DOMAIN_ID": "27",
        "NVIDIA_DRIVER_CAPABILITIES": "all",
        "NVIDIA_VISIBLE_DEVICES": "all",
        "__NV_PRIME_RENDER_OFFLOAD": "1",
        "__GLX_VENDOR_LIBRARY_NAME": "nvidia"
    },
    
    "customizations": {
        "vscode": {
            "settings": {
                "actionButtons": {
                    "defaultColor": "#ff0034",
                    "loadNpmCommands": false,
                    "reloadButton": "♻️",
                    "commands": [
                        {
                            "name": "Build Workspace",
                            "cwd": "/home/ros/scun_gun_ws", // Matches the new folder name
                            "color": "aqua",
                            "singleInstance": true,
                            "command": "colcon build --symlink-install --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && source install/setup.bash"
                        }
                    ]
                },
                "C_Cpp.default.intelliSenseMode": "gcc-x64",
                "files.autoSave": "onFocusChange"
            },
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "althack.ament-task-provider",
                "redhat.vscode-yaml",
                "streetsidesoftware.code-spell-checker",
                "seunlanlege.action-buttons",
                "DotJoshJohnson.xml"
            ]
        }
    },
    
    "initializeCommand": "xhost +local:root",
    "remoteUser": "ros"
}