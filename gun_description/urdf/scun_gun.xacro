<?xml version="1.0"?>
<robot name="scun_gun" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="imu.xacro" />

  <link name="base_link" />

  <link name="laser_link" />
  
  <joint name="laser_joint" type="fixed">
    <parent link="base_link" />
    <child link="laser_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <xacro:bno085_imu parent="base_link">
    <origin xyz="-0.1146 0.0 -0.0445" rpy="0 0 3.14159265" />
  </xacro:bno085_imu>

</robot>